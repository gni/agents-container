#!/bin/bash
set -e

# Base directory of the Orchestrated Trusted Transparent Execution Runtime (OTTER) project
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_DIR"

# Load root .env if it exists
if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs) 2>/dev/null || true
fi

# Directory where workspace instances are stored (default: instances)
INSTANCES_DIR="${INSTANCES_DIR:-instances}"

# Color Codes
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[1;30m'
BOLD='\033[1m'
RESET='\033[0m'

# Logger helpers to distinguish elements cleanly without emojis or uppercase
log_action() { echo -e "${CYAN}*${RESET} $1"; }
log_success() { echo -e "${GREEN}*${RESET} $1"; }
log_warn() { echo -e "${YELLOW}warning:${RESET} $1"; }
log_error() { echo -e "${RED}error:${RESET} $1"; }
log_info() { echo -e "${DIM}info:${RESET} $1"; }

# Help Menu
show_usage() {
    echo -e "usage: ./ac <command> [arguments] [options]\n"
    echo -e "commands:"
    echo -e "  ${GREEN}start${RESET}                               start the host daemon and proxy"
    echo -e "  ${GREEN}stop${RESET}                                stop the host daemon and proxy"
    echo -e "  ${GREEN}down${RESET}                                stop and remove all containers"
    echo -e "  ${GREEN}restart${RESET}                            restart proxy and update network rules"
    echo -e "  ${GREEN}status${RESET}                             check daemon and sandboxes status"
    echo -e "  ${GREEN}stats${RESET}                              stream real-time container resource stats"
    echo -e "  ${GREEN}ctop${RESET}                               launch container metrics dashboard (ctop)"
    echo -e "  ${GREEN}space${RESET}                              check disk space usage of agent components"
    echo -e "  ${GREEN}btop${RESET}                               launch interactive system resource monitor"
    echo -e "  ${GREEN}list${RESET}                               list running sandboxes and workspaces"
    echo -e "  ${GREEN}shell${RESET} [agent] <instance>          spawn an interactive sandbox shell"
    echo -e "  ${GREEN}run${RESET} [agent] <instance>            run sandbox in headless mode"
    echo -e "  ${GREEN}build${RESET} <agent> [--base]            force rebuild agent/base images"
    echo -e "  ${GREEN}logs${RESET} [host | proxy | gvisor]     view logs from host, proxy, or gvisor"
    echo -e "  ${GREEN}logs${RESET} agent <instance> [agent]      view logs from a specific agent instance"
    echo -e "  ${GREEN}clean${RESET} <instance>                  wipe instance credentials (preserve workspace)"
    echo -e "  ${GREEN}destroy${RESET} <instance>                wipe instance credentials and delete workspace"
    echo -e "  ${GREEN}clean-all${RESET}                         wipe credentials for all instances"
    echo -e "  ${GREEN}destroy-all${RESET}                       wipe credentials and delete all workspaces\n"
    echo -e "options:"
    echo -e "  --build, -b                       force rebuild agent image before running"
    echo -e "  --cpus <limit>                    limit cpu cores allocated to the sandbox"
    echo -e "  --memory, -m <limit>              limit memory allocated (e.g. 512m, 2g)"
    echo -e "  --gpus <devices>                  allocate gpu devices (e.g. all, none)\n"
    echo -e "examples:"
    echo -e "  ./ac start"
    echo -e "  ./ac shell pi my_pi_debug --cpus 2 -m 1g"
    echo -e "  ./ac shell my_pi_debug"
    echo -e "  ./ac list"
    exit 0
}

# Ensure DinD is running and healthy
ensure_dind_healthy() {
    if ! docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
        echo -e "starting host daemon..."
        docker compose up -d
    fi
    until docker exec ac-dind-host docker info >/dev/null 2>&1; do
        sleep 1
    done
    # Give namespaces and cgroups a brief moment to stabilize
    sleep 2
    
    echo -e "starting mesh network..."
    echo -e "  stream logs in another terminal: ./ac logs host -f\n"
    
    local spin='-\|/'
    local i=0
    local count=0
    local healthy=""
    local phase="starting docker daemon..."
    
    while true; do
        if [ $((count % 4)) -eq 0 ]; then
            healthy=$(docker exec ac-dind-host docker inspect -f '{{.State.Health.Status}}' ac-ottergate-1 2>&1 || echo "not_created")
            if [ "$healthy" = "healthy" ]; then
                break
            fi
            
            local bootstrap_done=false
            if docker exec ac-dind-host test -f /var/run/bootstrap_complete >/dev/null 2>&1; then
                bootstrap_done=true
            fi

            if [ "$bootstrap_done" = "true" ]; then
                if [ "$healthy" = "starting" ]; then
                    phase="verifying proxy..."
                else
                    phase="starting proxy..."
                fi
            else
                local logs
                logs=$(docker logs ac-dind-host 2>&1 || echo "")
                if echo "$logs" | grep -q "dind: starting ottergate proxy..."; then
                    phase="starting proxy..."
                elif echo "$logs" | grep -q "pre-building paranoid base image (otter_local/agent-base:paranoid)..."; then
                    phase="building paranoid base image (takes up to a minute)..."
                elif echo "$logs" | grep -q "pre-building base image (otter_local/agent-base)..."; then
                    phase="building base agent image (takes up to a minute)..."
                else
                    phase="starting docker daemon..."
                fi
            fi
            
            if [ "$bootstrap_done" = "true" ]; then
                if [ "$healthy" = "failed" ] || [ "$healthy" = "unhealthy" ] || [ "$healthy" = "exited" ] || [ "$healthy" = "not_created" ]; then
                    docker exec -e AGENT_TYPE="${AGENT_TYPE:-base}" -e INSTANCE_NAME="${INSTANCE_NAME:-base_session}" ac-dind-host docker compose -p ac -f /app/docker/docker-compose.inner.yml up -d ottergate >/dev/null 2>&1 || true
                fi
            fi
        fi
        
        printf "\r  [%c] %s\033[K" "${spin:i++%4:1}" "$phase"
        sleep 0.25
        count=$((count + 1))
    done
    
    printf "\r  * mesh network is online\033[K\n"
}

# Provision instances (folders, .env, secrets)
provision_instance() {
    local agent=$1
    local inst=$2
    mkdir -p "$INSTANCES_DIR"/"$inst"/home "$INSTANCES_DIR"/"$inst"/workspace "$INSTANCES_DIR"/"$inst"/.secrets
    chmod 700 "$INSTANCES_DIR"/"$inst"/home "$INSTANCES_DIR"/"$inst"/workspace "$INSTANCES_DIR"/"$inst"/.secrets

    if [ ! -f "$INSTANCES_DIR"/"$inst"/.env ]; then
        if [ -f config/templates/.env.example ]; then
            cp config/templates/.env.example "$INSTANCES_DIR"/"$inst"/.env
        else
            printf "GITHUB_TOKEN=your_token\nGITLAB_TOKEN=your_token\nGIT_NAME=\"Your Name\"\nGIT_EMAIL=\"your.email@example.com\"\n" > "$INSTANCES_DIR"/"$inst"/.env
        fi
    fi

    # Explicit lock to prevent type injection flaws across execution sessions
    if ! grep -qE "^AGENT_TYPE=" "$INSTANCES_DIR"/"$inst"/.env; then
        printf "\nAGENT_TYPE=%s\n" "$agent" >> "$INSTANCES_DIR"/"$inst"/.env
    fi

    # Create dummy secret files to allow bind mounts
    touch "$INSTANCES_DIR"/"$inst"/.secrets/github_token.txt "$INSTANCES_DIR"/"$inst"/.secrets/gitlab_token.txt
    chmod 600 "$INSTANCES_DIR"/"$inst"/.secrets/*.txt

    # Extract tokens from .env into secret files if present
    if [ -f "$INSTANCES_DIR"/"$inst"/.env ]; then
        grep -E "^(GITHUB_TOKEN|GH_TOKEN)=" "$INSTANCES_DIR"/"$inst"/.env | head -n 1 | cut -d '=' -f2- | tr -d '"' | tr -d "'" > "$INSTANCES_DIR"/"$inst"/.secrets/github_token.txt || true
        grep -E "^GITLAB_TOKEN=" "$INSTANCES_DIR"/"$inst"/.env | head -n 1 | cut -d '=' -f2- | tr -d '"' | tr -d "'" > "$INSTANCES_DIR"/"$inst"/.secrets/gitlab_token.txt || true
    fi
    chmod 400 "$INSTANCES_DIR"/"$inst"/.secrets/*.txt
}

# Determine paranoid mode and select base image
get_base_image_config() {
    local inst=$1
    local paranoid=false
    if [ -f "$INSTANCES_DIR/$inst/.env" ]; then
        if grep -qE "^PARANOID_MODE=true" "$INSTANCES_DIR/$inst/.env"; then
            paranoid=true
        fi
    elif [ -f "config/templates/.env.example" ]; then
        if grep -qE "^PARANOID_MODE=true" "config/templates/.env.example"; then
            paranoid=true
        fi
    fi
    if [ "$PARANOID_MODE" = "true" ]; then
        paranoid=true
    fi

    if [ "$paranoid" = "true" ]; then
        export BASE_IMAGE="otter_local/agent-base:paranoid"
        export BASE_IMAGE_TAG="paranoid"
        export DOCKERFILE_PATH="Dockerfile.paranoid"
    else
        export BASE_IMAGE="otter_local/agent-base:latest"
        export BASE_IMAGE_TAG="latest"
        export DOCKERFILE_PATH="Dockerfile.base"
    fi
}

if [ $# -lt 1 ]; then
    show_usage
fi

COMMAND=$1
shift

case "$COMMAND" in
    start)
        echo -e "starting mesh..."
        docker compose up -d
        ensure_dind_healthy
        echo -e "mesh started successfully."
        ;;
    stop)
        echo -e "stopping mesh..."
        docker compose stop
        echo -e "mesh stopped."
        ;;
    down)
        echo -e "tearing down mesh..."
        docker compose down -v
        echo -e "mesh torn down."
        ;;
    status)
        echo -e "host container status:"
        docker ps -f name=ac-dind-host
        echo -e "\nhost container resource usage:"
        docker stats --no-stream ac-dind-host
        
        echo -e "\nnested containers status:"
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec ac-dind-host docker ps
            echo -e "\nnested containers resource usage:"
            docker exec ac-dind-host docker stats --no-stream
        else
            echo -e "error: host is not running."
        fi
        ;;
    shell|run)
        AGENT=""
        INSTANCE=""
        FORCE_BUILD=false
        CPUS_LIMIT=""
        MEMORY_LIMIT=""
        GPUS_LIMIT=""
        
        # Parse arguments
        while [ $# -gt 0 ]; do
            case "$1" in
                --build|-b)
                    FORCE_BUILD=true
                    shift
                    ;;
                --cpus)
                    CPUS_LIMIT="$2"
                    shift 2
                    ;;
                --memory|-m)
                    MEMORY_LIMIT="$2"
                    shift 2
                    ;;
                --gpus)
                    GPUS_LIMIT="$2"
                    shift 2
                    ;;
                *)
                    if [ -z "$AGENT" ]; then
                        AGENT="$1"
                    elif [ -z "$INSTANCE" ]; then
                        INSTANCE="$1"
                    fi
                    shift
                    ;;
            esac
        done
        
        # Context-Aware Structural Pattern Evaluation Matrix
        if [ -n "$AGENT" ] && [ -z "$INSTANCE" ]; then
            if [ -d "$INSTANCES_DIR/$AGENT" ]; then
                # Context A: Explicitly matched an existing directory instance
                INSTANCE="$AGENT"
                if [ -f "$INSTANCES_DIR/$INSTANCE/.env" ] && grep -qE "^AGENT_TYPE=" "$INSTANCES_DIR/$INSTANCE/.env"; then
                    AGENT=$(grep -E "^AGENT_TYPE=" "$INSTANCES_DIR/$INSTANCE/.env" | cut -d '=' -f2- | tr -d '"' | tr -d "'")
                else
                    AGENT=$(echo "$INSTANCE" | cut -d'_' -f1)
                fi
            elif [ -d "agents/blueprints/$AGENT" ]; then
                # Context B: Explicitly matched a raw blueprint target string
                INSTANCE="${AGENT}_session"
            else
                # Context C: Implicit dynamic name parsing (Lazy Initialization Strategy)
                INSTANCE="$AGENT"
                MATCHED_BLUE=false
                for b_path in agents/blueprints/*; do
                    if [ -d "$b_path" ]; then
                        b_test=$(basename "$b_path")
                        if [[ "$INSTANCE" == "${b_test}"* ]] || [[ "$INSTANCE" == *"${b_test}"* ]]; then
                            AGENT="$b_test"
                            MATCHED_BLUE=true
                            break
                        fi
                    fi
                done
                if [ "$MATCHED_BLUE" = false ]; then
                    AGENT="base"
                fi
            fi
        fi

        AGENT=${AGENT:-base}
        INSTANCE=${INSTANCE:-${AGENT}_session}
        if [ ${#INSTANCE} -eq 1 ]; then
            INSTANCE="${INSTANCE}_"
        fi

        # Strict Namespace Isolation Check: Prevent mutating an existing instance with a different blueprint type
        if [ -d "$INSTANCES_DIR/$INSTANCE" ]; then
            tracking_file="$INSTANCES_DIR/$INSTANCE/.env"
            if [ -f "$tracking_file" ]; then
                detected_type=$(grep -E "^AGENT_TYPE=" "$tracking_file" | cut -d '=' -f2- | tr -d '"' | tr -d "'" || true)
                if [ -n "$detected_type" ] && [ "$detected_type" != "$AGENT" ]; then
                    echo -e "${RED}error: name collision detected. instance '${INSTANCE}' is strictly bound to agent blueprint type '${detected_type}', cannot re-initialize or execute as type '${AGENT}'.${RESET}" >&2
                    exit 1
                fi
            fi
        fi

        if [ ! -d "agents/blueprints/$AGENT" ]; then
            echo -e "error: blueprint '${AGENT}' does not exist"
            echo -e "available blueprints:"
            for d in agents/blueprints/*; do
                if [ -d "$d" ]; then
                    echo -e "  - $(basename "$d")"
                fi
            done
            exit 1
        fi
        export AGENT_TYPE=$AGENT
        export INSTANCE_NAME=$INSTANCE
        export HOST_UID=$(id -u)
        export HOST_GID=$(id -g)

        provision_instance "$AGENT" "$INSTANCE"
        ensure_dind_healthy
        get_base_image_config "$INSTANCE"

        # Load resource limits from the instance's .env file if present and not overridden by CLI
        if [ -f "$INSTANCES_DIR/$INSTANCE/.env" ]; then
            [ -z "$CPUS_LIMIT" ] && CPUS_LIMIT=$(grep -E "^AGENT_CPUS=" "$INSTANCES_DIR"/"$INSTANCE"/.env | cut -d '=' -f2- | tr -d '"' | tr -d "'" || true)
            [ -z "$MEMORY_LIMIT" ] && MEMORY_LIMIT=$(grep -E "^(AGENT_MEMORY|MEMORY_LIMIT)=" "$INSTANCES_DIR"/"$INSTANCE"/.env | head -n 1 | cut -d '=' -f2- | tr -d '"' | tr -d "'" || true)
            [ -z "$GPUS_LIMIT" ] && GPUS_LIMIT=$(grep -E "^AGENT_GPUS=" "$INSTANCES_DIR"/"$INSTANCE"/.env | cut -d '=' -f2- | tr -d '"' | tr -d "'" || true)
        fi

        LIMITS_OPT=""
        [ -n "$CPUS_LIMIT" ] && LIMITS_OPT="$LIMITS_OPT --cpus=$CPUS_LIMIT"
        [ -n "$MEMORY_LIMIT" ] && LIMITS_OPT="$LIMITS_OPT --memory=$MEMORY_LIMIT"
        [ -n "$GPUS_LIMIT" ] && LIMITS_OPT="$LIMITS_OPT --gpus=$GPUS_LIMIT"

        ENTRYPOINT_OPT=""
        SHELL_CMD=""

        if [ "$COMMAND" = "shell" ]; then
            RUNNING_CONTAINER=$(docker exec ac-dind-host docker ps --filter label=ac.instance="${INSTANCE}" --filter status=running -q || true)
            
            if [ -n "$RUNNING_CONTAINER" ]; then
                CONTAINER_ID=$(echo "$RUNNING_CONTAINER" | head -n 1)
                echo -e "attaching to running sandbox ${INSTANCE}..."
                docker exec -it ac-dind-host docker exec -it -u node "${CONTAINER_ID}" /bin/bash
                exit 0
            fi
            
            SHELL_CMD="/bin/bash"
            echo -e "starting interactive shell..."
        else
            echo -e "starting agent..."
        fi

        BASE_EXISTS=$(docker exec ac-dind-host docker images -q "${BASE_IMAGE}" 2>/dev/null || true)
        if [ -z "$BASE_EXISTS" ] || [ "$FORCE_BUILD" = true ]; then
            echo -e "building ${BASE_IMAGE} using ${DOCKERFILE_PATH}..."
            docker exec -it ac-dind-host docker build -t "${BASE_IMAGE}" -f "/app/docker/agent/${DOCKERFILE_PATH}" /app
        fi

        IMAGE_EXISTS=$(docker exec ac-dind-host docker images -q "otter_local/agent-${AGENT}-agent:${BASE_IMAGE_TAG}" 2>/dev/null || true)
        if [ -z "$IMAGE_EXISTS" ] || [ "$FORCE_BUILD" = true ]; then
            echo -e "building agent image..."
            docker exec -it ac-dind-host docker build -t otter_local/agent-${AGENT}-agent:${BASE_IMAGE_TAG} -f /app/docker/agent/Dockerfile.agent --build-arg AGENT_TYPE=${AGENT} --build-arg BASE_IMAGE=${BASE_IMAGE} /app
        else
            echo -e "reusing cached agent image (use --build to rebuild)"
        fi

        echo ""
        docker exec -it \
            -e AGENT_TYPE \
            -e INSTANCE_NAME \
            -e BASE_IMAGE \
            -e BASE_IMAGE_TAG \
            -e GH_SECRET_TARGET_PATH \
            -e GL_SECRET_TARGET_PATH \
            -e GIT_NAME \
            -e GIT_EMAIL \
            -e HOST_UID \
            -e HOST_GID \
            -e TERM="${TERM:-xterm-256color}" \
            -e AGENT_CPUS="${CPUS_LIMIT:-0}" \
            -e AGENT_MEMORY="${MEMORY_LIMIT:-0}" \
            -e INSTANCES_DIR \
            ac-dind-host \
            docker compose -p ac -f /app/docker/docker-compose.inner.yml --env-file /app/"$INSTANCES_DIR"/"$INSTANCE"/.env run $ENTRYPOINT_OPT --no-deps --name ${INSTANCE_NAME} --rm agent $SHELL_CMD
        ;;
    logs)
        LAYER=$1
        shift || true
        case "$LAYER" in
            host)
                docker logs "$@" ac-dind-host
                ;;
            proxy)
                docker exec -it ac-dind-host docker logs "$@" ac-ottergate-1
                ;;
            agent)
                INST=$1
                shift || true
                if [ -z "$INST" ]; then
                    echo -e "error: specify instance name"
                    echo -e "usage: ./ac logs agent <instance>"
                    exit 1
                fi
                if [ ${#INST} -eq 1 ]; then
                    INST="${INST}_"
                fi
                docker exec -it ac-dind-host docker logs "$@" "$INST"
                ;;
            gvisor)
                echo -e "gvisor sandbox logs:"
                if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
                    LOG_FILES=$(docker exec ac-dind-host sh -c 'find /var/log/runsc/ /var/log/gvisor/ -name "runsc.log.*" 2>/dev/null' || true)
                    if [ -n "$LOG_FILES" ]; then
                        LATEST_LOG=$(docker exec ac-dind-host sh -c 'ls -t $(find /var/log/runsc/ /var/log/gvisor/ -name "runsc.log.*" 2>/dev/null) 2>/dev/null | head -n 1')
                        echo -e "latest log file: $LATEST_LOG\n"
                        docker exec -it ac-dind-host tail -n 100 "$LATEST_LOG"
                    else
                        echo "no active gvisor logs found. enable GVISOR_DEBUG=true to generate logs."
                    fi
                else
                    echo -e "error: host is offline."
                fi
                ;;
            *)
                echo -e "error: invalid logs layer. choose 'host', 'proxy', 'gvisor', or 'agent'."
                exit 1
                ;;
        esac
        ;;
    list)
        echo -e "running sandboxes:"
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            ps_out=$(docker exec ac-dind-host docker ps --filter label=ac.instance --format '{{.Names}}\t{{.Status}}\t{{.Image}}\t{{.Label "ac.instance"}}' 2>/dev/null || true)
            
            printf "  \033[1;30m%-36s %-20s %-32s\033[0m\n" "name" "status" "image"
            printf "  \033[1;30m----------------------------------------------------------------------------------------\033[0m\n"
            
            if [ -n "$ps_out" ]; then
                echo "$ps_out" | while IFS=$'\t' read -r name status image inst_label; do
                    short_name=${inst_label:-${name#agent_instance_}}
                    short_name=${short_name,,}
                    status=${status,,}
                    image=${image,,}
                    printf "  %-36s %-20s %-32s\n" "$short_name" "$status" "$image"
                done
            else
                printf "  \033[0;33m%-36s\033[0m\n" "no running sandboxes"
            fi
            printf "  \033[1;30m----------------------------------------------------------------------------------------\033[0m\n"
        else
            echo -e "error: host is offline."
        fi
        
        echo -e "\navailable workspaces:"
        printf "  \033[1;30m%-36s %-12s %-12s\033[0m\n" "name" "size" "secrets"
        printf "  \033[1;30m------------------------------------------------------------\033[0m\n"
        
        if [ -d "$INSTANCES_DIR" ] && [ "$(ls -A "$INSTANCES_DIR" 2>/dev/null)" ]; then
            for d in "$INSTANCES_DIR"/*; do
                if [ -d "$d" ]; then
                    inst_name=$(basename "$d")
                    inst_name=${inst_name,,}
                    
                    size=$(du -sh "$d" | cut -f1)
                    size=${size,,}
                    
                    has_secrets="no"
                    secrets_color="\033[0;33m"
                    if [ -d "$d/.secrets" ] && [ "$(ls -A "$d/.secrets" 2>/dev/null)" ]; then
                        has_data=false
                        for f in "$d"/.secrets/*.txt; do
                            if [ -s "$f" ]; then
                                has_data=true
                                break
                            fi
                        done
                        if [ "$has_data" = true ]; then
                            has_secrets="yes"
                            secrets_color="\033[0;32m"
                        fi
                    fi
                    
                    printf "  %-36s %-12s ${secrets_color}%-12s\033[0m\n" "$inst_name" "$size" "$has_secrets"
                fi
            done
        else
            printf "  \033[0;33m%-36s\033[0m\n" "no workspaces found"
        fi
        printf "  \033[1;30m------------------------------------------------------------\033[0m\n"
        ;;
    clean)
        INST=$1
        if [ -z "$INST" ]; then
            echo -e "error: specify instance name"
            exit 1
        fi
        if [ ${#INST} -eq 1 ]; then
            INST="${INST}_"
        fi
        echo -e "cleaning credentials for $INST..."
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            container_ids=$(docker exec ac-dind-host docker ps -aq --filter label=ac.instance="$INST" 2>/dev/null)
            if [ -n "$container_ids" ]; then
                docker exec ac-dind-host docker rm -f $container_ids 2>/dev/null || true
            fi
            docker exec ac-dind-host docker rm -f "$INST" 2>/dev/null || true
        fi
        rm -rf "$INSTANCES_DIR"/"$INST"/.secrets
        rm -f "$INSTANCES_DIR"/"$INST"/.env
        echo -e "cleaned."
        ;;
    destroy)
        INST=$1
        if [ -z "$INST" ]; then
            echo -e "error: specify instance name"
            exit 1
        fi
        if [ ${#INST} -eq 1 ]; then
            INST="${INST}_"
        fi
        echo -e "destroying $INST (this will delete workspace files)..."
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            container_ids=$(docker exec ac-dind-host docker ps -aq --filter label=ac.instance="$INST" 2>/dev/null)
            if [ -n "$container_ids" ]; then
                docker exec ac-dind-host docker rm -f $container_ids 2>/dev/null || true
            fi
            docker exec ac-dind-host docker rm -f "$INST" 2>/dev/null || true
        fi
        rm -rf "$INSTANCES_DIR"/"$INST"
        echo -e "destroyed."
        ;;
    clean-all)
        echo -e "cleaning all credentials..."
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec ac-dind-host docker compose -p ac -f /app/docker/docker-compose.inner.yml down -v 2>/dev/null || true
        fi
        rm -rf "$INSTANCES_DIR"/*/.secrets
        rm -f "$INSTANCES_DIR"/*/.env
        echo -e "cleaned all."
        ;;
    destroy-all)
        echo -e "destroying all containers, volumes, and workspaces..."
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec ac-dind-host docker compose -p ac -f /app/docker/docker-compose.inner.yml down -v 2>/dev/null || true
        fi
        docker compose down -v 2>/dev/null || true
        rm -rf "$INSTANCES_DIR"/*
        echo -e "destroyed all."
        ;;
    build)
        AGENT=""
        FORCE_BASE=false
        NO_CACHE_OPT=""
        for arg in "$@"; do
            if [ "$arg" = "--base" ] || [ "$arg" = "-b" ]; then
                FORCE_BASE=true
            elif [ "$arg" = "--no-cache" ]; then
                NO_CACHE_OPT="--no-cache"
            elif [ -z "$AGENT" ]; then
                AGENT="$arg"
            fi
        done
        AGENT=${AGENT:-base}
        if [ ! -d "agents/blueprints/$AGENT" ]; then
            echo -e "error: blueprint '${AGENT}' does not exist"
            exit 1
        fi
        
        get_base_image_config "${AGENT}_session"
        ensure_dind_healthy
        
        BASE_EXISTS=$(docker exec ac-dind-host docker images -q "${BASE_IMAGE}" 2>/dev/null || true)
        if [ -z "$BASE_EXISTS" ] || [ "$FORCE_BASE" = true ]; then
            echo -e "building ${BASE_IMAGE} using ${DOCKERFILE_PATH}..."
            docker exec -it ac-dind-host docker build $NO_CACHE_OPT -t "${BASE_IMAGE}" -f "/app/docker/agent/${DOCKERFILE_PATH}" /app
        else
            echo -e "reusing cached ${BASE_IMAGE} (use --base to rebuild)"
        fi
        
        echo -e "building agent blueprint '${AGENT}'..."
        docker exec -it ac-dind-host docker build $NO_CACHE_OPT -t otter_local/agent-${AGENT}-agent:${BASE_IMAGE_TAG} -f /app/docker/agent/Dockerfile.agent --build-arg AGENT_TYPE=${AGENT} --build-arg BASE_IMAGE=${BASE_IMAGE} /app
        echo -e "built agent blueprint: ${AGENT}"
        ;;
    stats)
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            echo -e "streaming nested container stats (press ctrl+c to exit)..."
            docker exec -it ac-dind-host docker stats
        else
            echo -e "error: host is not running. run './ac start' first."
        fi
        ;;
    space|df)
        echo -e "\033[1;30m--- Host Storage Usage ---\033[0m"
        df -h . | grep -v Filesystem || true
        echo -e "\n\033[1;30m--- Inner Docker Storage Usage ---\033[0m"
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec ac-dind-host df -h /var/lib/docker | grep -v Filesystem || true
            echo -e "\n\033[1;30m--- Inner Docker System df ---\033[0m"
            docker exec ac-dind-host docker system df || true
            echo -e "\n\033[1;30m--- Persistent Workspaces Disk Usage ---\033[0m"
            docker exec ac-dind-host sh -c "du -sh /app/${INSTANCES_DIR:-instances}/* 2>/dev/null" || echo "no persistent workspaces found."
            echo -e "\n\033[1;30m--- gVisor Logs Disk Usage ---\033[0m"
            docker exec ac-dind-host du -sh /var/log/gvisor 2>/dev/null || true
            echo -e "\n\033[1;30m--- Container Writable Layer Sizes ---\033[0m"
            docker exec ac-dind-host docker ps -s --format "table {{.Names}}\t{{.Size}}" || true
        else
            echo -e "error: host is not running. run './ac start' first."
        fi
        ;;
    btop)
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec -it ac-dind-host btop --force-utf "$@"
        else
            echo -e "error: host is not running. run './ac start' first."
        fi
        ;;
    ctop)
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec -it ac-dind-host ctop "$@"
        else
            echo -e "error: host is not running. run './ac start' first."
        fi
        ;;
    restart)
        echo -e "restarting proxy..."
        if docker ps --format '{{.Names}}' | grep -q "^ac-dind-host$"; then
            docker exec ac-dind-host docker compose -p ac -f /app/docker/docker-compose.inner.yml restart ottergate
            docker exec ac-dind-host chmod +x /app/src/network/update-iptables.sh
            docker exec ac-dind-host /bin/bash /app/src/network/update-iptables.sh
            echo -e "proxy restarted successfully."
        else
            echo -e "error: host is not running. run './ac start' first."
        fi
        ;;
    *)
        show_usage
        ;;
esac