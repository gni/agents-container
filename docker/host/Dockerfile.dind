FROM docker:29-dind

# Install runtime dependencies (including bash, crun, iptables, etc.)
RUN apk add --no-cache bash curl crun libcap xz python3 nodejs openssl ctop

# Force legacy iptables to prevent nftables initialization errors in nested containers
RUN ln -sf /sbin/iptables-legacy /sbin/iptables && \
    ln -sf /sbin/ip6tables-legacy /sbin/ip6tables && \
    ln -sf /sbin/iptables-legacy-save /sbin/iptables-save && \
    ln -sf /sbin/iptables-legacy-restore /sbin/iptables-restore && \
    ln -sf /sbin/ip6tables-legacy-save /sbin/ip6tables-save && \
    ln -sf /sbin/ip6tables-legacy-restore /sbin/ip6tables-restore

# Download and install latest gVisor (runsc) and containerd-shim-runsc-v1 binaries for x86_64
RUN wget https://storage.googleapis.com/gvisor/releases/release/latest/x86_64/runsc && \
    wget https://storage.googleapis.com/gvisor/releases/release/latest/x86_64/containerd-shim-runsc-v1 && \
    chmod a+rx runsc containerd-shim-runsc-v1 && \
    mv runsc containerd-shim-runsc-v1 /usr/local/bin/

# Copy Docker daemon configuration supporting gVisor (runsc) and crun
COPY docker/host/daemon.json /etc/docker/daemon.json

# Create app directory and copy codebase
WORKDIR /app
COPY . .

# Ensure scripts are executable if they exist
RUN chmod +x /app/docker/host/entrypoint-dind.sh && \
    if [ -d /app/tests ]; then chmod +x /app/tests/*.sh /app/tests/*.py /app/tests/*.js 2>/dev/null || true; fi

# Set the entrypoint to bootstrap our isolated environment
ENTRYPOINT ["/app/docker/host/entrypoint-dind.sh"]
