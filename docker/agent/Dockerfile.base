# syntax=docker/dockerfile:1
FROM debian:trixie-slim AS glibc-provider
FROM node:26-alpine

ARG GITLAB_CLI_VERSION=1.97.0

ENV NODE_ENV=production
ENV NPM_CONFIG_LOGLEVEL=warn
ENV HOME=/home/node

RUN apk add --no-cache \
        git \
        curl \
        wget \
        ca-certificates \
        procps \
        build-base \
        python3 \
        python3-dev \
        zsh \
        vim \
        github-cli \
        tmux \
        bash \
        shadow

# Copy custom CA certificates for enterprise SSL proxy/registry access during build
COPY config/ottergate/certs/custom/ /tmp/custom-certs/
RUN if [ -d /tmp/custom-certs ] && [ "$(ls -A /tmp/custom-certs)" ]; then \
        cp /tmp/custom-certs/*.crt /usr/local/share/ca-certificates/ 2>/dev/null || true; \
        for f in /tmp/custom-certs/*.pem; do \
            if [ -f "$$f" ]; then \
                name_pem=$${f##*/}; \
                name_no_ext=$${name_pem%.pem}; \
                cp "$$f" "/usr/local/share/ca-certificates/$$name_no_ext.crt"; \
            fi; \
        done; \
        update-ca-certificates; \
        rm -rf /tmp/custom-certs; \
    fi

# Set environment variables so build-time tools (curl, wget, etc.) trust the custom CA
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
ENV REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Copy glibc libraries and loader from Debian for glibc binary compatibility (e.g. antigravity)
COPY --from=glibc-provider /usr/lib/x86_64-linux-gnu /usr/lib/x86_64-linux-gnu
RUN mkdir -p /lib64 \
    && ln -sf /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 /lib64/ld-linux-x86-64.so.2

ENV LD_LIBRARY_PATH="/lib:/usr/lib:/usr/local/lib"

RUN curl -sL "https://gitlab.com/gitlab-org/cli/-/releases/v${GITLAB_CLI_VERSION}/downloads/glab_${GITLAB_CLI_VERSION}_linux_amd64.tar.gz" | tar -xz -C /usr/local bin/glab

# Create a no-op/bypass init-guard script to satisfy agent entrypoint
RUN printf '#!/bin/sh\nexec "$@"\n' > /usr/local/bin/init-guard \
    && chmod +x /usr/local/bin/init-guard



USER root


RUN mkdir -p /workspace \
    && chown -R node:node /workspace

WORKDIR /workspace