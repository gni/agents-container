# syntax=docker/dockerfile:1
FROM node:26-trixie-slim

ARG GITLAB_CLI_VERSION=1.97.0

ENV NODE_ENV=production
ENV DEBIAN_FRONTEND=noninteractive
ENV NPM_CONFIG_LOGLEVEL=warn
ENV HOME=/home/node

RUN mkdir -p -m 755 /etc/apt/keyrings \
    && apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        wget \
        ca-certificates \
        procps \
        build-essential \
        python3 \
        python3-dev \
        python3-venv \
        zsh \
        vim \
        gh \
        tmux \
    && wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*


RUN curl -sL "https://gitlab.com/gitlab-org/cli/-/releases/v${GITLAB_CLI_VERSION}/downloads/glab_${GITLAB_CLI_VERSION}_linux_amd64.tar.gz" | tar -xz -C /usr/local bin/glab

# Create a no-op/bypass init-guard script to satisfy agent entrypoint
RUN printf '#!/bin/sh\nexec "$@"\n' > /usr/local/bin/init-guard \
    && chmod +x /usr/local/bin/init-guard



USER root


RUN mkdir -p /workspace \
    && chown -R node:node /workspace

WORKDIR /workspace