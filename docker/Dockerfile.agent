# syntax=docker/dockerfile:1
FROM local/agent-base:latest

ARG AGENT_TYPE

COPY agents/${AGENT_TYPE}/install.sh /tmp/install.sh

RUN chmod +x /tmp/install.sh && /tmp/install.sh && rm /tmp/install.sh

ENV LD_PRELOAD="/usr/local/lib/fs_vault.so /usr/local/lib/net_proxy.so"
ENV PATH="/home/node/.local/bin:${PATH}"

ENTRYPOINT ["/usr/local/bin/init-guard", "sh", "/usr/local/bin/agent-run.sh"]
CMD []